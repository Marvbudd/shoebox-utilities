#!/usr/bin/env node

/**
 * mkcol - Create a shoebox collection file from media files in the current directory
 * 
 * Usage: mkcol [OPTIONS] <key> <text> <title>
 * 
 * Arguments:
 *   key   - Unique identifier for the collection (no spaces or special chars)
 *   text  - Short description for dropdown display
 *   title - Human-readable description of the collection
 * 
 * Options:
 *   --accessions-file PATH  Path to accessions.json file (required)
 *   --dry-run               Preview collection without creating file
 *   --help                  Show this help message
 * 
 * Scans current directory for supported media files:
 *   - Images: .jpg, .jpeg, .JPG, .JPEG
 *   - Video: .mp4, .MP4
 *   - Audio: .mp3, .MP3
 * 
 * Looks up accession numbers from accessions.json based on the link (filename).
 * Creates a collection JSON file in the collections directory.
 */

const fs = require('fs');
const path = require('path');

// ANSI color codes
const colors = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  cyan: '\x1b[36m'
};

// Supported file extensions
const SUPPORTED_EXTENSIONS = [
  '.jpg', '.jpeg', '.JPG', '.JPEG',
  '.mp4', '.MP4',
  '.mp3', '.MP3'
];

// Options
let accessionsFilePath = null;
let dryRun = false;

/**
 * Show usage information
 */
function showUsage() {
  console.log(`${colors.blue}Usage:${colors.reset} mkcol [OPTIONS] <key> <text> <title>`);
  console.log('');
  console.log('Create a Shoebox collection from media files in current directory.');
  console.log('');
  console.log('Options:');
  console.log('  --accessions-file PATH  Path to accessions.json file (required)');
  console.log('  --dry-run               Preview collection without creating file');
  console.log('  --help                  Show this help message');
  console.log('');
  console.log('Arguments:');
  console.log('  key    Unique identifier (letters, numbers, hyphens, underscores only)');
  console.log('  text   Short description for dropdown display');
  console.log('  title  Human-readable description of the collection');
  console.log('');
  console.log('Examples:');
  console.log('  mkcol --accessions-file ~/archive/accessions.json \\');
  console.log('        summer2024 "Summer 2024" "Summer Vacation Photos 2024"');
  console.log('');
  console.log('  mkcol --accessions-file ~/archive/accessions.json --dry-run \\');
  console.log('        trip "Trip Photos" "Family Trip to Europe"');
  process.exit(0);
}

/**
 * Load and parse accessions.json
 */
function loadAccessions() {
  if (!fs.existsSync(accessionsFilePath)) {
    console.error(`${colors.red}Error: accessions.json not found at ${accessionsFilePath}${colors.reset}`);
    process.exit(1);
  }
  
  try {
    const fileContent = fs.readFileSync(accessionsFilePath, 'utf8');
    const data = JSON.parse(fileContent);
    return data.accessions.item || [];
  } catch (error) {
    console.error(`${colors.red}Error reading accessions.json: ${error.message}${colors.reset}`);
    process.exit(1);
  }
}

/**
 * Build a map of link -> accession for quick lookup
 */
function buildLinkToAccessionMap(items) {
  const map = new Map();
  for (const item of items) {
    if (item.link && item.accession) {
      map.set(item.link, item.accession);
    }
  }
  return map;
}

/**
 * Get collections directory path
 */
function getCollectionsDir() {
  const accessionsDir = path.dirname(accessionsFilePath);
  const collectionsDir = path.join(accessionsDir, 'collections');
  
  // Check if collections directory exists, create if needed (unless dry-run)
  if (!fs.existsSync(collectionsDir)) {
    if (dryRun) {
      console.log(`${colors.yellow}[Dry run] Would create collections directory: ${collectionsDir}${colors.reset}\n`);
    } else {
      fs.mkdirSync(collectionsDir, { recursive: true });
      console.log(`${colors.green}Created collections directory: ${collectionsDir}${colors.reset}\n`);
    }
  }
  
  return collectionsDir;
}

/**
 * Parse command line arguments
 */
function parseArguments() {
  const args = process.argv.slice(2);
  const positionalArgs = [];
  
  let i = 0;
  while (i < args.length) {
    const arg = args[i];
    
    if (arg === '--help') {
      showUsage();
    } else if (arg === '--dry-run') {
      dryRun = true;
      i++;
    } else if (arg === '--accessions-file') {
      if (i + 1 >= args.length) {
        console.error(`${colors.red}Error: --accessions-file requires a path argument${colors.reset}`);
        process.exit(1);
      }
      accessionsFilePath = args[i + 1];
      i += 2;
    } else if (arg.startsWith('--')) {
      console.error(`${colors.red}Error: Unknown option: ${arg}${colors.reset}`);
      console.error('');
      showUsage();
    } else {
      positionalArgs.push(arg);
      i++;
    }
  }
  
  // Check if --accessions-file was provided
  if (!accessionsFilePath) {
    console.error(`${colors.red}Error: --accessions-file is required${colors.reset}`);
    console.error('');
    showUsage();
  }
  
  // Convert to absolute path
  accessionsFilePath = path.resolve(accessionsFilePath);
  
  // Check if we have exactly 3 positional arguments
  if (positionalArgs.length !== 3) {
    console.error(`${colors.red}Error: Expected 3 arguments (key, text, title)${colors.reset}`);
    console.error(`Got ${positionalArgs.length}: ${positionalArgs.join(', ')}`);
    console.error('');
    showUsage();
  }
  
  const [key, text, title] = positionalArgs;
  
  // Validate key (no spaces or special characters)
  if (!/^[a-zA-Z0-9_-]+$/.test(key)) {
    console.error(`${colors.red}Error: Key must contain only letters, numbers, hyphens, and underscores${colors.reset}`);
    console.error(`Invalid key: "${key}"`);
    process.exit(1);
  }
  
  return { key, text, title };
}

/**
 * Scan current directory for supported media files
 */
function scanMediaFiles() {
  const currentDir = process.cwd();
  const files = fs.readdirSync(currentDir);
  
  const mediaFiles = files.filter(file => {
    const ext = path.extname(file);
    return SUPPORTED_EXTENSIONS.includes(ext);
  }).sort(); // Sort alphabetically for consistent ordering
  
  return mediaFiles;
}

/**
 * Create collection object with accession numbers from accessions.json
 */
function createCollection(key, text, title, mediaFiles, linkToAccessionMap) {
  const itemKeys = [];
  const warnings = [];
  
  for (const file of mediaFiles) {
    const accession = linkToAccessionMap.get(file);
    
    if (!accession) {
      warnings.push(`${colors.yellow}Warning: Link "${file}" not found in accessions.json - skipping${colors.reset}`);
      continue;
    }
    
    itemKeys.push({
      accession: accession,
      link: file
    });
  }
  
  return {
    collection: {
      key,
      text,
      title,
      itemKeys
    },
    warnings
  };
}

/**
 * Write collection to JSON file in collections directory
 */
function writeCollectionFile(collection, collectionsDir) {
  const filename = `${collection.key}.json`;
  const filepath = path.join(collectionsDir, filename);
  
  // Check if file already exists
  if (fs.existsSync(filepath)) {
    console.error(`${colors.red}Error: Collection file "${filename}" already exists in ${collectionsDir}${colors.reset}`);
    process.exit(1);
  }
  
  if (dryRun) {
    console.log(`${colors.yellow}[Dry run] Would create: ${filepath}${colors.reset}`);
    return filepath;
  }
  
  const json = JSON.stringify(collection, null, 2);
  fs.writeFileSync(filepath, json);
  
  return filepath;
}

/**
 * Main function
 */
function main() {
  // Header
  console.log(`${colors.blue}╔════════════════════════════════════════════════════════════════╗${colors.reset}`);
  console.log(`${colors.blue}║${colors.reset}              ${colors.cyan}Create Shoebox Collection${colors.reset}                    ${colors.blue}║${colors.reset}`);
  console.log(`${colors.blue}╚════════════════════════════════════════════════════════════════╝${colors.reset}`);
  console.log('');
  
  // Parse arguments
  const { key, text, title } = parseArguments();
  
  console.log(`${colors.cyan}Configuration:${colors.reset}`);
  console.log(`  Key:               ${key}`);
  console.log(`  Text:              ${text}`);
  console.log(`  Title:             ${title}`);
  console.log(`  Accessions file:   ${accessionsFilePath}`);
  console.log(`  Current directory: ${process.cwd()}`);
  if (dryRun) {
    console.log(`  ${colors.yellow}Mode: DRY RUN (no files will be created)${colors.reset}`);
  }
  console.log('');
  
  // Load accessions.json
  console.log(`${colors.cyan}Loading accessions.json...${colors.reset}`);
  const items = loadAccessions();
  const linkToAccessionMap = buildLinkToAccessionMap(items);
  console.log(`${colors.green}✓ Loaded ${linkToAccessionMap.size} accession entries${colors.reset}\n`);
  
  // Get collections directory
  const collectionsDir = getCollectionsDir();
  
  // Scan for media files
  console.log(`${colors.cyan}Scanning for media files...${colors.reset}`);
  const mediaFiles = scanMediaFiles();
  
  if (mediaFiles.length === 0) {
    console.error(`${colors.red}Error: No supported media files found in current directory${colors.reset}`);
    console.error(`Supported extensions: ${SUPPORTED_EXTENSIONS.join(', ')}`);
    process.exit(1);
  }
  
  console.log(`${colors.green}✓ Found ${mediaFiles.length} media file(s)${colors.reset}\n`);
  
  // Create collection
  console.log(`${colors.cyan}Building collection...${colors.reset}`);
  const { collection, warnings } = createCollection(key, text, title, mediaFiles, linkToAccessionMap);
  
  // Display warnings if any
  if (warnings.length > 0) {
    console.log('');
    warnings.forEach(warning => console.log(`  ${warning}`));
    console.log('');
  }
  
  if (collection.itemKeys.length === 0) {
    console.error(`${colors.red}Error: No valid items found for collection (all files were skipped)${colors.reset}`);
    process.exit(1);
  }
  
  // Display items to be included
  console.log(`${colors.green}✓ Including ${collection.itemKeys.length} item(s) in collection:${colors.reset}\n`);
  collection.itemKeys.forEach((item, index) => {
    console.log(`  ${(index + 1).toString().padStart(3)}. ${item.link} ${colors.cyan}→${colors.reset} ${item.accession}`);
  });
  console.log('');
  
  // Write to file
  const filepath = writeCollectionFile(collection, collectionsDir);
  
  // Summary
  console.log(`${colors.blue}════════════════════════════════════════════════════════════════${colors.reset}`);
  if (dryRun) {
    console.log(`${colors.yellow}Dry run complete. Collection would have been created:${colors.reset}`);
    console.log(`  File:  ${path.basename(filepath)}`);
    console.log(`  Items: ${collection.itemKeys.length}`);
    console.log(`  Path:  ${filepath}`);
    console.log('');
    console.log(`${colors.yellow}Run without --dry-run to create the collection file.${colors.reset}`);
  } else {
    console.log(`${colors.green}✓ Collection created successfully!${colors.reset}`);
    console.log(`  File:  ${path.basename(filepath)}`);
    console.log(`  Items: ${collection.itemKeys.length}`);
    console.log(`  Path:  ${filepath}`);
  }
  console.log(`${colors.blue}════════════════════════════════════════════════════════════════${colors.reset}`);
}

// Run the script
main();
